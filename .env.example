# =============================
# 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を設定してください
# コマンド例: cp .env.example .env
# =============================

# Stripe 秘密鍵（バックエンドのみで使用 - 絶対に公開しないこと）
STRIPE_SECRET_KEY=sk_test_your_key_here

# Stripe 公開鍵（フロントエンドから参照可能）
STRIPE_PUBLIC_KEY=pk_test_your_key_here

# Stripe Webhook署名シークレット（Webhook検証用）
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# JWT認証用の秘密鍵（本番環境では必ず変更すること）
SECRET_KEY=your-jwt-secret-key

# 管理者メールアドレス（このメールアドレスで新規登録すると自動的に管理者になる）
# 例: ADMIN_EMAIL=admin@example.com
ADMIN_EMAIL=

# =============================
# SMTP（メール送信）設定
# メール認証機能を使用する場合は以下を設定してください
# Gmail の場合: smtp.gmail.com, ポート587、アプリパスワードを使用
# =============================

# SMTPサーバーホスト（例: smtp.gmail.com）
SMTP_HOST=smtp.gmail.com

# SMTPポート（587=STARTTLS推奨）
SMTP_PORT=587

# SMTPログインユーザー（送信元メールアドレス）
SMTP_USER=your-email@gmail.com

# SMTPパスワード（Gmailの場合はアプリパスワードを使用）
SMTP_PASSWORD=your-app-password

# 送信元メールアドレス（省略時は SMTP_USER と同じ）
SMTP_FROM=your-email@gmail.com
